#!/bin/bash
#
# git-force-push
#
# Force pushes the current branch with a confirmation prompt.

branch=$(git rev-parse --abbrev-ref HEAD)

printf "Are you sure you want to force push to '%s'? [y/N] " "$branch"
read -r response

if [[ "$response" =~ ^[Yy]$ ]]; then
  git push --force-with-lease
else
  echo "Force push cancelled."
fi
